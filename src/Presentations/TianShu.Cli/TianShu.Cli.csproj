    <ProjectReference Include="..\..\Provider\TianShu.Provider.Abstractions\TianShu.Provider.Abstractions.csproj" />
    <ProjectReference Include="..\..\Provider\TianShu.Provider.Anthropic\TianShu.Provider.Anthropic.csproj" />
    <ProjectReference Include="..\..\Provider\TianShu.Provider.Google\TianShu.Provider.Google.csproj" />
