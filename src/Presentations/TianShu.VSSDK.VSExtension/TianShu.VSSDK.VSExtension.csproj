<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{D3D3E562-251F-4A73-A3A8-C8128EBCB5AA}</ProjectGuid>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectTypeGuids>{82B43B9B-A64C-4715-B499-D71E9CA2BD60};{60DC8134-EBA5-43B8-BCC9-BB4BC16C2548};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>TianShu.VSSDK.VSExtension</RootNamespace>
    <AssemblyName>TianShu.VSSDK.VSExtension</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <MinimumVisualStudioVersion>18.0</MinimumVisualStudioVersion>
    <VisualStudioVersion Condition="'$(VisualStudioVersion)' == ''">18.0</VisualStudioVersion>
    <VSToolsPath Condition="'$(VSToolsPath)' == ''">$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)</VSToolsPath>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <Deterministic>true</Deterministic>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RuntimeIdentifier>win</RuntimeIdentifier>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>true</CopyOutputSymbolsToOutputDirectory>
    <StartAction>Program</StartAction>
    <StartProgram Condition="'$(DevEnvDir)' != ''">$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix TianShuExp</StartArguments>
    <VSSDKTargetPlatformRegRootSuffix>TianShuExp</VSSDKTargetPlatformRegRootSuffix>
    <TianShuVsixVersion>0.1.3</TianShuVsixVersion>
    <TianShuNativeResourceFile>$(IntermediateOutputPath)TianShuMenuResources.res</TianShuNativeResourceFile>
    <Win32Resource>$(TianShuNativeResourceFile)</Win32Resource>
    <TianShuVsInstallDir Condition="'$(TianShuVsInstallDir)' == '' and '$(VSINSTALLDIR)' != ''">$([System.IO.Path]::GetFullPath('$(VSINSTALLDIR)'))</TianShuVsInstallDir>
    <TianShuVsInstallDir Condition="'$(TianShuVsInstallDir)' == '' and '$(DevEnvDir)' != ''">$([System.IO.Path]::GetFullPath('$(DevEnvDir)..\..'))</TianShuVsInstallDir>
    <TianShuVsInstallDir Condition="'$(TianShuVsInstallDir)' == '' and Exists('C:\Program Files\Microsoft Visual Studio\18\Enterprise\Common7\IDE\devenv.exe')">C:\Program Files\Microsoft Visual Studio\18\Enterprise</TianShuVsInstallDir>
    <TianShuVsInstallDir Condition="'$(TianShuVsInstallDir)' == '' and Exists('C:\Program Files\Microsoft Visual Studio\18\Professional\Common7\IDE\devenv.exe')">C:\Program Files\Microsoft Visual Studio\18\Professional</TianShuVsInstallDir>
    <TianShuVsInstallDir Condition="'$(TianShuVsInstallDir)' == '' and Exists('C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\devenv.exe')">C:\Program Files\Microsoft Visual Studio\18\Community</TianShuVsInstallDir>
    <TianShuVsInstallDir Condition="'$(TianShuVsInstallDir)' == '' and Exists('C:\Program Files\Microsoft Visual Studio\18\Preview\Common7\IDE\devenv.exe')">C:\Program Files\Microsoft Visual Studio\18\Preview</TianShuVsInstallDir>
    <TianShuRcExe Condition="'$(TianShuRcExe)' == '' and '$(TianShuVsInstallDir)' != ''">$(TianShuVsInstallDir)\SDK\ScopeCppSDK\vc15\SDK\bin\rc.exe</TianShuRcExe>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Design" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="ConversationMarkdownRenderer.cs" />
    <Compile Include="TianShuConversationToolWindow.cs" />
    <Compile Include="TianShuConversationToolWindowCommand.cs" />
    <Compile Include="TianShuConversationToolWindowControl.xaml.cs">
      <DependentUpon>TianShuConversationToolWindowControl.xaml</DependentUpon>
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="TianShuVssdkPackage.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="Services\TianShuDevPathLocator.cs" />
    <Compile Include="..\..\Provider\TianShu.Provider.Abstractions\OpenAiAppCatalogCompatibilityKeys.cs">
      <Link>Provider\OpenAiAppCatalogCompatibilityKeys.cs</Link>
    </Compile>
    <Compile Include="Services\TianShuSidecarBridge.cs" />
    <Compile Include="Services\TianShuSidecarSourceTypes.cs" />
    <Compile Include="Services\TianShuSidecarThreadOptionTypes.cs" />
    <Compile Include="Services\TianShuVsTextContextService.cs" />
  </ItemGroup>
  <ItemGroup>
    <Page Include="TianShuConversationToolWindowControl.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="VSPackage.resx">
      <MergeWithCTO>true</MergeWithCTO>
      <ManifestResourceName>VSPackage</ManifestResourceName>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
    <VSCTCompile Include="TianShuVssdkPackage.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="$(IntermediateOutputPath)TianShuVssdkPackage.cto">
      <LogicalName>Menus.ctmenu</LogicalName>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" ExcludeAssets="runtime" NoWarn="NU1604" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" NoWarn="NU1604" PrivateAssets="all" />
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="'$(VSToolsPath)' != '' and Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />
  <Target Name="EnsureTianShuRcToolAvailable"
          BeforeTargets="GenerateTianShuMenuWin32Resource"
          Condition="!Exists('$(TianShuRcExe)')">
    <Error Text="未找到 rc.exe，请安装 Visual Studio 18.x（Community/Professional/Enterprise/Preview 之一），或设置 VSINSTALLDIR / TianShuVsInstallDir / TianShuRcExe。" />
  </Target>
  <Target Name="GenerateTianShuMenuWin32Resource"
          BeforeTargets="CoreCompile"
          DependsOnTargets="VSCTCompile"
          Condition="Exists('$(TianShuRcExe)')">
    <WriteLinesToFile File="$(IntermediateOutputPath)TianShuMenuResources.rc" Overwrite="true" Lines="1000 CTMENU &quot;TianShuVssdkPackage.cto&quot;" />
    <Exec Command="&quot;$(TianShuRcExe)&quot; /nologo /fo &quot;$(TianShuNativeResourceFile)&quot; &quot;$(IntermediateOutputPath)TianShuMenuResources.rc&quot;" />
  </Target>
  <Target Name="NormalizeTianShuVsixManifestVersion" AfterTargets="DetokenizeVsixManifestFile">
    <XmlPeek XmlInputPath="$(IntermediateVsixManifest)" Query="/*[local-name()='PackageManifest']/*[local-name()='Metadata']/*[local-name()='Identity']/@Version">
      <Output TaskParameter="Result" PropertyName="CurrentTianShuVsixVersion" />
    </XmlPeek>
    <XmlPoke XmlInputPath="$(IntermediateVsixManifest)" Query="/*[local-name()='PackageManifest']/*[local-name()='Metadata']/*[local-name()='Identity']/@Version" Value="$(TianShuVsixVersion)" Condition="'$(CurrentTianShuVsixVersion)' != '$(TianShuVsixVersion)'" />
  </Target>
  <Target Name="BuildTianShuSidecar"
          BeforeTargets="Build"
          Condition="'$(DesignTimeBuild)' != 'true' and Exists('..\TianShu.VSSDK.Sidecar\TianShu.VSSDK.Sidecar.csproj')">
    <MSBuild Projects="..\TianShu.VSSDK.Sidecar\TianShu.VSSDK.Sidecar.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration)" />
  </Target>
</Project>

