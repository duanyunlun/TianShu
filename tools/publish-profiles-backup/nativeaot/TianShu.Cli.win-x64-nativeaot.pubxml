<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <PublishDir>bin\Release\net10.0\win-x64\publish-nativeaot\</PublishDir>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <EnablePreviewFeatures>true</EnablePreviewFeatures>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishAot>true</PublishAot>
    <TrimMode>full</TrimMode>
    <IlcOptimizationPreference>Speed</IlcOptimizationPreference>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <CopyOutputSymbolsToPublishDirectory>false</CopyOutputSymbolsToPublishDirectory>
    <StripSymbols>true</StripSymbols>
    <IlcGeneratePdb>false</IlcGeneratePdb>
    <IlcGenerateMapFile>false</IlcGenerateMapFile>
    <InvariantGlobalization>true</InvariantGlobalization>
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    <!-- CLI 仍会承接 JSON envelope、TOML 和 markdown 渲染；先允许已知 trim 分析提示，后续再逐步补 source-gen。 -->
    <NoWarn>$(NoWarn);IL2026;IL2067;IL2070;IL2075;IL2104;IL3050</NoWarn>
  </PropertyGroup>
</Project>
