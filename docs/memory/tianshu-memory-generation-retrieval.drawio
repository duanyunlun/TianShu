        <mxCell id="title" value="TianShu Memory Plane - 记忆生成与取回主链路" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=center;verticalAlign=middle;fontColor=#1f2937;" vertex="1" parent="1">
