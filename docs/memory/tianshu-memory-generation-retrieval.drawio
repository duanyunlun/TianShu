        </mxCell>
        <mxCell id="subtitle" value="核心原则：写入慢而可审计；读取快且 context-first；LLM / embedding 只生成候选、相似性和 proposal，不直接写入高置信事实。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;align=center;verticalAlign=middle;fontColor=#4b5563;" vertex="1" parent="1">
          <mxGeometry x="260" y="60" width="1280" height="30" as="geometry"/>
